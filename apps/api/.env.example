# =============================================================================
# RAGMark API — Environment Configuration
# =============================================================================

# --- LLM Providers ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Default provider: openai | anthropic
LLM_PROVIDER=openai

# --- Database ---
# sqlite (dev) or postgresql+asyncpg (prod)
DATABASE_URL=sqlite+aiosqlite:///./data/ragmark.db

# --- ChromaDB ---
# persist_directory for local dev, host:port for remote
CHROMA_PERSIST_DIR=./data/chroma

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
ENVIRONMENT=development
